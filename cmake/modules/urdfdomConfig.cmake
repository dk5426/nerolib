  pkg_check_modules(urdfdom REQUIRED urdfdom)

  add_library(urdfdom::urdfdom INTERFACE IMPORTED)
  target_include_directories(urdfdom::urdfdom INTERFACE ${urdfdom_INCLUDE_DIRS})
  target_link_libraries(urdfdom::urdfdom INTERFACE ${urdfdom_LIBRARIES})
  target_link_directories(urdfdom::urdfdom INTERFACE ${urdfdom_LIBRARY_DIRS})
  target_link_options(urdfdom::urdfdom INTERFACE ${urdfdom_LDFLAGS})

  set(urdfdom_FOUND TRUE)
  
