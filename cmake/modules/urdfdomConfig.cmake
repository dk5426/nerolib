    add_library(urdfdom::urdf_model_state ALIAS urdfdom::urdfdom)
  endif()
  if(NOT TARGET urdfdom::urdf_model)
    add_library(urdfdom::urdf_model ALIAS urdfdom::urdfdom)
  endif()
  if(NOT TARGET urdfdom::urdf_world)
    add_library(urdfdom::urdf_world ALIAS urdfdom::urdfdom)
  endif()
  if(NOT TARGET urdfdom::urdf_sensor)
    add_library(urdfdom::urdf_sensor ALIAS urdfdom::urdfdom)
  endif()
