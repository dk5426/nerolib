<robot name="nero">
  <link name="dummy_link" />

  <!-- rpy='-2.356194 -1.570791 -2.356194' matches nero-welded-base-and-lift.mjcf euler='1.5708 0 1.5708'.
       Verified: Rx(1.5708)@Ry(0)@Rz(1.5708) = Rz(-2.356)@Ry(-1.571)@Rx(-2.356) -->
  <joint name="base_to_dummy" type="fixed">
    <parent link="dummy_link" />
    <child link="base_link" />
    <origin xyz="-0.005 -0.125 0.0575" rpy="-2.356194 -1.570791 -2.356194" />
  </joint>

  <link name="base_link">
